{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Esquema Legacy de Escenarios de Evacuación",
  "type": "object",
  "properties": {
    "configuracion": {
      "type": "object",
      "properties": {
        "ancho": { "type": "number" },
        "alto": { "type": "number" }
      },
      "required": ["ancho", "alto"]
    },
    "hitos": {
      "type": "object",
      "description": "Diccionario clave-valor con los nodos del grafo (ID -> [x, y])",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "conexiones": {
      "type": "array",
      "description": "Lista de aristas que conectan los hitos",
      "items": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 2,
        "maxItems": 2
      }
    },
    "agentesspawn": {
      "type": "array",
      "description": "Coordenadas [x, y] de inicio de los evacuados",
      "items": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 2,
        "maxItems": 2
      }
    },
    "muros": {
      "type": "array",
      "description": "Geometría pre-calculada de los obstáculos",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tipo": { "type": "string", "enum": ["muro_exterior", "muro_interior", "puerta"] },
          "poligono": {
            "type": "array",
            "description": "Las 4 esquinas exactas del muro generadas por el pre-procesador",
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "minItems": 4,
            "maxItems": 4
          },
          "directriz": {
            "type": "object",
            "description": "Vector original (opcional, por si el simulador quiere pintar la línea central)"
          }
        },
        "required": ["id", "tipo", "poligono"]
      }
    }
  },
  "required": ["configuracion", "hitos", "conexiones", "agentesspawn", "muros"]
}