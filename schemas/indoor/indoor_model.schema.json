{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/indoor_data_model/indoor_model.schema.json",
  "title": "Indoor Data Model — indoor_model.json",
  "description": "Draft schema for the spatial/topological indoor model exported by SpatialEngine. It is intentionally IndoorJSON-like: IndoorFeatures -> ThematicLayer -> PrimalSpaceLayer / DualSpaceLayer. It excludes population, agents, beacons, hazards, simulation configuration and results; those belong to scenario_model.json or EvacEngine outputs.",
  "type": "object",
  "allOf": [
    { "$ref": "#/$defs/IndoorFeatures" }
  ],
  "$defs": {
    "IndoorFeatures": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "IndoorFeatures" },
        "metadata": { "$ref": "#/$defs/Metadata" },
        "crs": { "$ref": "#/$defs/CoordinateReferenceSystem" },
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Level" },
          "uniqueItems": true
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ThematicLayer" },
          "uniqueItems": true
        },
        "layerConnections": {
          "type": "array",
          "items": { "$ref": "#/$defs/InterLayerConnection" },
          "uniqueItems": true
        },
        "verticalConnectors": {
          "type": "array",
          "items": { "$ref": "#/$defs/VerticalConnector" },
          "uniqueItems": true
        },
        "sourceFeatures": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceFeature" },
          "description": "Optional authoring/source geometry used to derive CellSpaces, CellBoundaries and the DualSpaceLayer. This is not the primal model itself."
        },
        "indoorDataModel": { "$ref": "#/$defs/IndoorDataModelInfo" }
      },
      "required": ["id", "featureType", "metadata", "crs", "levels", "layers"],
      "additionalProperties": false,
      "$comment": "Deliberately excludes agent_spawns, agents, beacons, hazards, simulation and results."
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "modifiedAt": { "type": "string", "format": "date-time" },
        "author": { "type": "string" },
        "organization": { "type": "string" },
        "generator": { "type": "string" },
        "source": { "type": "string" },
        "comment": { "type": "string" }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "IndoorDataModelInfo": {
      "type": "object",
      "properties": {
        "modelName": { "const": "indoor_data_model" },
        "modelVersion": { "type": "string" },
        "profile": { "type": "string", "enum": ["indoorjson_like", "indoorjson_strict_view", "project_extension"] },
        "compatibility": { "type": "string" },
        "supersedes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["modelName", "modelVersion", "profile"],
      "additionalProperties": false
    },
    "CoordinateReferenceSystem": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["local", "projected", "global"] },
        "srid": { "type": "integer" },
        "unit": { "type": "string", "enum": ["meters", "feet"] },
        "origin": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          },
          "required": ["x", "y"],
          "additionalProperties": false
        },
        "axisOrder": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["type", "unit"],
      "additionalProperties": false
    },
    "Level": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "levelIndex": { "type": "integer" },
        "order": { "type": "integer" },
        "elevationM": { "type": "number" },
        "floorZ": { "type": "number" },
        "ceilingZ": { "type": "number" },
        "heightM": { "type": "number" },
        "spatialExtent2D": { "$ref": "#/$defs/Polygon" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "levelIndex"],
      "additionalProperties": false
    },
    "ThematicLayer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "ThematicLayer" },
        "semanticExtension": { "type": "boolean" },
        "theme": { "type": "string", "enum": ["Physical", "Virtual", "Tags", "Unknown", "TopographicNavigation", "SensorCoverage", "Security"] },
        "name": { "type": "string" },
        "level": { "type": "string" },
        "primalSpace": { "$ref": "#/$defs/PrimalSpaceLayer" },
        "dualSpace": { "$ref": "#/$defs/DualSpaceLayer" },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "semanticExtension", "theme", "primalSpace", "dualSpace"],
      "additionalProperties": false
    },
    "PrimalSpaceLayer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "PrimalSpaceLayer" },
        "creationDatetime": { "type": "string", "format": "date-time" },
        "terminationDatetime": { "type": "string", "format": "date-time" },
        "cellSpaceMember": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/CellSpace" },
          "uniqueItems": true
        },
        "cellBoundaryMember": {
          "type": "array",
          "items": { "$ref": "#/$defs/CellBoundary" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "cellSpaceMember"],
      "additionalProperties": false
    },
    "CellSpace": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "CellSpace" },
        "cellSpaceName": { "type": "string" },
        "level": { "type": "string" },
        "poi": { "type": "boolean" },
        "duality": { "type": "string" },
        "cellSpaceGeom": {
          "type": "object",
          "properties": {
            "geometry2D": { "$ref": "#/$defs/Polygon" },
            "geometry3D": { "$ref": "#/$defs/Geometry3DPlaceholder" }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "boundedBy": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "externalReference": { "$ref": "#/$defs/ExternalReference" },
        "navigationType": {
          "type": "string",
          "enum": ["NavigableSpace", "GeneralSpace", "TransferSpace", "NonNavigableSpace", "ObjectSpace", "Unclassified"]
        },
        "navigationClass": {
          "type": "string",
          "enum": ["NavigableSpace", "NonNavigableSpace", "Unclassified"]
        },
        "category": { "type": "string" },
        "function": { "type": "string" },
        "locomotionTypes": {
          "type": "array",
          "items": { "$ref": "#/$defs/LocomotionType" },
          "uniqueItems": true
        },
        "sourceFeatureRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "poi"],
      "additionalProperties": false,
      "$comment": "navigationType keeps the IndoorJSON Core featureType stable while exposing Navigation semantics for the project profile."
    },
    "CellBoundary": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "CellBoundary" },
        "isVirtual": { "type": "boolean" },
        "duality": { "type": "string" },
        "cellBoundaryGeom": {
          "type": "object",
          "properties": {
            "geometry2D": { "$ref": "#/$defs/LineString" },
            "geometry3D": { "$ref": "#/$defs/Polygon" }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "externalReference": { "$ref": "#/$defs/ExternalReference" },
        "navigationBoundaryType": { "type": "string", "enum": ["NavigableBoundary", "NonNavigableBoundary", "Unclassified"] },
        "navigableBoundaryFunction": { "type": "string", "enum": ["AnchorBoundary", "ConnectionBoundary"] },
        "traversable": { "type": "boolean" },
        "cellRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "sourceFeatureRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "isVirtual"],
      "additionalProperties": false
    },
    "DualSpaceLayer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "DualSpaceLayer" },
        "creationDatetime": { "type": "string", "format": "date-time" },
        "terminationDatetime": { "type": "string", "format": "date-time" },
        "isLogical": { "type": "boolean" },
        "isDirected": { "type": "boolean" },
        "nodeMember": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Node" },
          "uniqueItems": true
        },
        "edgeMember": {
          "type": "array",
          "items": { "$ref": "#/$defs/Edge" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "isLogical", "isDirected", "nodeMember"],
      "additionalProperties": false
    },
    "Node": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "Node" },
        "duality": { "type": "string" },
        "geometry": { "$ref": "#/$defs/Point" },
        "connects": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "duality"],
      "additionalProperties": false
    },
    "Edge": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "Edge" },
        "duality": { "type": "string" },
        "weight": { "type": "number" },
        "geometry": { "$ref": "#/$defs/LineString" },
        "connects": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "relationshipType": {
          "type": "string",
          "enum": ["adjacency", "connectivity", "accessibility", "containment", "vertical_connectivity", "logical", "unknown"]
        },
        "traversable": { "type": "boolean" },
        "boundaryRef": { "type": "string" },
        "transferSpaceRef": { "type": "string" },
        "locomotionTypes": {
          "type": "array",
          "items": { "$ref": "#/$defs/LocomotionType" },
          "uniqueItems": true
        },
        "widthM": { "type": "number" },
        "capacityPersons": { "type": "number" },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "weight", "connects"],
      "additionalProperties": false
    },
    "InterLayerConnection": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "InterLayerConnection" },
        "connectedLayers": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "connectedNodes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "connectedCells": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "typeOfTopoExpression": { "type": "string", "enum": ["CONTAINS", "OVERLAPS", "EQUALS", "WITHIN", "CROSSES", "OTHERS"] },
        "comment": { "type": "string" }
        ,
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "connectedLayers", "typeOfTopoExpression"],
      "additionalProperties": false
    },
    "SourceFeature": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "featureType": { "const": "SourceFeature" },
        "sourceType": {
          "type": "string",
          "enum": [
            "wall_centerline",
            "door_centerline",
            "window_centerline",
            "exit_centerline",
            "virtual_boundary_line",
            "room_polygon",
            "corridor_polygon",
            "stair_footprint",
            "ramp_footprint",
            "elevator_footprint",
            "column_footprint",
            "other"
          ]
        },
        "level": { "type": "string" },
        "geometry": {
          "oneOf": [
            { "$ref": "#/$defs/Point" },
            { "$ref": "#/$defs/LineString" },
            { "$ref": "#/$defs/Polygon" }
          ]
        },
        "catalogRef": { "type": "string" },
        "derivedCellSpaceRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "derivedBoundaryRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "featureType", "sourceType", "geometry"],
      "additionalProperties": false
    },
    "ExternalReference": {
      "type": "object",
      "properties": {
        "externalObject": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "uri": { "type": "string", "format": "uri" }
          },
          "required": ["name", "uri"],
          "additionalProperties": false
        },
        "informationSystem": { "type": "string", "format": "uri" }
      },
      "required": ["externalObject", "informationSystem"],
      "additionalProperties": false
    },
    "LocomotionType": {
      "type": "string",
      "enum": ["Flying", "Rolling", "Walking", "Unspecified"]
    },
    "ConnectorEndpoint": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "level": { "type": "string" },
        "footprint": {
          "oneOf": [
            { "$ref": "#/$defs/Polygon" },
            {
              "type": "array",
              "minItems": 4,
              "items": {
                "type": "array",
                "minItems": 2,
                "maxItems": 3,
                "items": { "type": "number" }
              }
            }
          ]
        },
        "entrySide": { "type": "string", "enum": ["north", "south", "east", "west"] },
        "exitSide": { "type": "string", "enum": ["north", "south", "east", "west"] },
        "openSides": {
          "type": "array",
          "items": { "type": "string", "enum": ["north", "south", "east", "west"] },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "level", "footprint"],
      "additionalProperties": false
    },
    "VerticalConnector": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "connectorType": { "type": "string", "enum": ["Stair", "Ramp", "Elevator"] },
        "scope": { "type": "string", "enum": ["same_level", "inter_level"] },
        "endpoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/ConnectorEndpoint" },
          "minItems": 1
        },
        "sourceLevel": { "type": "string" },
        "targetLevel": { "type": "string" },
        "fromElevationM": { "type": "number" },
        "toElevationM": { "type": "number" },
        "directionality": { "type": "string" },
        "locomotionTypes": {
          "type": "array",
          "items": { "$ref": "#/$defs/LocomotionType" },
          "uniqueItems": true
        },
        "attributes": { "$ref": "#/$defs/FreeformAttributes" }
      },
      "required": ["id", "connectorType", "scope", "endpoints", "sourceLevel"],
      "additionalProperties": false
    },
    "Point": {
      "type": "object",
      "properties": {
        "type": { "const": "Point" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": { "type": "number" }
        }
      },
      "required": ["type", "coordinates"],
      "additionalProperties": false
    },
    "LineString": {
      "type": "object",
      "properties": {
        "type": { "const": "LineString" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 3,
            "items": { "type": "number" }
          }
        }
      },
      "required": ["type", "coordinates"],
      "additionalProperties": false
    },
    "Polygon": {
      "type": "object",
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 4,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 3,
              "items": { "type": "number" }
            }
          }
        }
      },
      "required": ["type", "coordinates"],
      "additionalProperties": false
    },
    "Geometry3DPlaceholder": {
      "type": "object",
      "description": "Reserved placeholder for future 3D geometry support. The current TFG profile is primarily 2D/2.5D."
    },
    "FreeformAttributes": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
